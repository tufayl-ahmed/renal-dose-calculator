# Local development template only. Do not put real secrets in Git.

AI_FREE_MODE=true
FREE_AI_DAILY_REQUEST_LIMIT=200
WHATSAPP_GRAPH_VERSION=v23.0

# Cloudflare Pages secrets. Set these with `wrangler pages secret put ...`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=

# Experimental unofficial OpenWA bridge. Keep disabled unless testing with a spare number.
OPENWA_EXPERIMENT_ENABLED=false
OPENWA_API_BASE_URL=
OPENWA_API_KEY=
OPENWA_SESSION_ID=
OPENWA_WEBHOOK_SECRET=
OPENWA_ALLOW_GROUPS=false

# Optional persistent AI usage counter binding if added later.
AI_USAGE=
